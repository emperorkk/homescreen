{
  "name": "homescreen",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Android-first PWA timer hosted on Cloudflare Workers.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
